---
import { Sparkles } from "@lucide/astro";
import type { Destination } from "@data/destinations";

type Props = {
  curiosity: Destination["curiosity"];
};

const { curiosity } = Astro.props;
---

<section class="px-[var(--site-pad)] py-16 sm:py-24" aria-labelledby="curiosita">
  <div class="mx-auto max-w-[760px]">
    <article class="reveal rounded-[8px] border border-oro/30 bg-[oklch(1_0_0/.42)] p-6 shadow-glow backdrop-blur-sm sm:p-8">
      <div class="mb-7 grid size-12 place-items-center rounded-full bg-verde-profondo text-avorio">
        <Sparkles size={20} stroke-width={1.7} aria-hidden="true" />
      </div>
      <h2 id="curiosita" class="serif text-[clamp(1.75rem,5.6vw,2.6rem)] font-semibold leading-[1.08] tracking-[-0.005em]">
        Una curiosità
      </h2>
      <h3 class="mt-5 text-[1.18rem] font-semibold text-verde-profondo">{curiosity.title}</h3>
      <p class="mt-3 text-[1.08rem] leading-8 text-inchiostro-morbido">{curiosity.text}</p>
    </article>
  </div>
</section>
