---
import type { Destination } from "@data/destinations";

type Props = {
  moments: Destination["moments"];
};

const { moments } = Astro.props;
---

<section class="px-[var(--site-pad)] py-16 sm:py-24" aria-labelledby="vivremo">
  <div class="mx-auto max-w-[1120px]">
    <div class="mb-8 flex items-end justify-between gap-6">
      <h2 id="vivremo" class="serif reveal max-w-[12ch] text-[clamp(1.95rem,6vw,3.2rem)] font-semibold leading-[1.04] tracking-[-0.01em] sm:leading-[1.02]">
        Cosa vivremo insieme
      </h2>
    </div>

    <div class="grid gap-3 min-[480px]:grid-cols-2 lg:grid-cols-4">
      {moments.map((moment, index) => {
        const Icon = moment.icon;
        return (
          <article
            class="reveal min-h-[220px] rounded-[8px] border border-inchiostro/10 bg-white/42 p-5 shadow-[0_18px_40px_oklch(0.19_0.025_82/.08)] backdrop-blur-sm"
            style={`--delay:${index * 90}ms`}
          >
            <div class="mb-7 grid size-11 place-items-center rounded-full bg-oro-chiaro text-verde-profondo">
              <Icon size={20} stroke-width={1.65} aria-hidden="true" />
            </div>
            <h3 class="serif text-[1.65rem] font-semibold leading-tight">{moment.title}</h3>
            <p class="mt-3 text-[1rem] leading-7 text-inchiostro-morbido">{moment.text}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>
